assign pin=rst 	test_function= +SC; 	# test_mode
assign pin=scan_en 	test_function= +SE; 	# shift_enable
assign pin=rclk 	test_function= -ES; 	
assign pin=wclk 	test_function= -ES; 	
assign pin=scan_in 	test_function= SI0;
assign pin=scan_out 	test_function= SO0;
assign pin=DFT_sdi_1 	test_function= SI1;
assign pin=DFT_sdo_1 	test_function= SO1;
